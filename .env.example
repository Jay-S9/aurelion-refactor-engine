# ── Aurelion Refactor Engine — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in your values.
# .env is loaded automatically on startup.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# AI planning (claude ai command)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server mode API auth
# Generate with: aurelion auth generate-key
AURELION_API_KEY=aur_...

# Rate limiting for server mode (requests per minute per IP, default 60)
AURELION_RATE_LIMIT=60
